# A hermetic, offline IPv4-only "target" for NAT64/DNS64 tests:
#   - busybox httpd serves a known static response on :80
#   - dnsmasq answers *only* for target.test with this container's own IPv4
#     address (acts as the Dns64Default forwarder for the ydn64-under-test,
#     so tests never depend on live internet DNS/HTTP).
FROM alpine:3.20
RUN apk add --no-cache dnsmasq busybox-extras
RUN mkdir -p /www && printf 'nat64-target-ok\n' > /www/index.html
COPY target-entrypoint.sh /entrypoint.sh
RUN chmod +x /entrypoint.sh
ENTRYPOINT ["/entrypoint.sh"]
